#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

input=$(cat)
skill=$(printf '%s' "$input" | grep -o '"skill":"[^"]*"' | head -1 | cut -d'"' -f4)
[ "$skill" != "superpowers:requesting-code-review" ] && exit 0

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

context="<IMPORTANT_CODE_REVIEW_PREREQUISITE>
Before conducting the code review, you MUST first invoke knowledger to retrieve relevant coding standards and best practices.

Steps:
1. First call the \`claude-code-knowledger:knowledger\` skill
2. Use query keywords such as: \"coding standards\", \"code review checklist\", \"best practices\", etc.
3. Conduct a comprehensive code review based on the retrieved knowledge

This ensures the review is based on the project's established standards and specifications.
</IMPORTANT_CODE_REVIEW_PREREQUISITE>"

context_escaped=$(escape_for_json "$context")

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$context_escaped" | cat
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$context_escaped" | cat
fi

exit 0
