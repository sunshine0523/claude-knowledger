#!/usr/bin/env bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"

skill_content=$(cat "${PLUGIN_ROOT}/skills/knowledger/SKILL.md" 2>&1 || echo "Error reading knowledger skill")

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

skill_escaped=$(escape_for_json "$skill_content")
context="<EXTREMELY_IMPORTANT>\nYou have Knowledger, a knowledge base plugin.\n\nBefore answering, you MUST invoke the \`claude-code-knowledger:knowledger\` skill using the Skill tool.\n\n**Below is the full content of your 'claude-code-knowledger:knowledger' skill for reference:**\n\n${skill_escaped}\n</EXTREMELY_IMPORTANT>"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
  printf '{\n  "additional_context": "%s"\n}\n' "$context" | cat
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
  printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "UserPromptSubmit",\n    "additionalContext": "%s"\n  }\n}\n' "$context" | cat
else
  printf '{\n  "additionalContext": "%s"\n}\n' "$context" | cat
fi

exit 0
