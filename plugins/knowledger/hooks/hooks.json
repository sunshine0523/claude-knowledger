{
  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/git-sync\"",
            "timeout": 60
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/precheck\"",
            "timeout": 5
          }
        ]
      }
    ],
    "SkillInvoke": [
      {
        "match": {
          "skill": "superpowers:requesting-code-review"
        },
        "hooks": [
          {
            "type": "command",
            "command": "bash \"${CLAUDE_PLUGIN_ROOT}/hooks/code-review-precheck\"",
            "timeout": 5
          }
        ]
      }
    ]
  }
}
